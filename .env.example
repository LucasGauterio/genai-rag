# LLM Provider: 'openrouter' or 'gemini'
LLM_PROVIDER=gemini

# LLM Provider Configuration (OpenRouter)
# Get your API key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Google Gemini Configuration (required if LLM_PROVIDER=gemini)
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash


# Local Embeddings Configuration (Ollama)
# Base URL for the Ollama service running locally or via Docker
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model used to embed text chunks (pulled automatically by Docker Compose)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
